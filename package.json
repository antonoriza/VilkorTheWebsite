{
  "name": "propertypulse",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run --filter='*' dev",
    "dev:web": "bun run --filter=@propertypulse/web dev",
    "dev:api": "bun run --filter=@propertypulse/api dev",
    "propertyPulse": "./dev-utilities/bin/propertyPulse",
    "build": "bun run --filter='*' build",
    "typecheck": "bun run --filter='*' typecheck"
  }
}
