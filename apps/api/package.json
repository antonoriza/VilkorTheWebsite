{
  "name": "@propertypulse/api",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "bun run tsc --noEmit",
    "db:generate": "bunx --bun drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:seed": "bun run src/db/seed.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@propertypulse/shared": "workspace:*",
    "better-auth": "^1.2.0",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.30.0",
    "typescript": "~5.7.2"
  }
}
